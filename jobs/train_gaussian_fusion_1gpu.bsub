set -e

module purge
module load conda/4.11.0
module load cuda/12.9.1
conda activate gsplat

cd /home/izi2sgh/MYDATA/sunny/ContinuousSR
nvidia-smi

export TORCH_CUDA_ARCH_LIST="9.0"

python train.py \
    --config configs/train/train-m3svd-fusion.yaml \
    --save_dir ./save/gaussian_fusion_1gpu \
    --wandb_project GaussianFusion \
    --wandb_run "exp01-1gpu" \
    --batch_size 64
